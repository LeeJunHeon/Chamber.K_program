{
    "// ================================================================": "",
    "// Chamber-K 사용자 설정 파일 (config_user.json)": "",
    "// - 이 파일을 수정하고 프로그램을 재시작하면 설정이 적용됩니다.": "",
    "// - 이 파일이 없거나 오류가 있으면 config.py 기본값이 사용됩니다.": "",
    "// - // 로 시작하는 줄은 주석으로 처리되어 무시됩니다.": "",
    "// ================================================================ ": "",

    "// ------- 시리얼 포트 설정 -------": "",
    "// MFC 연결 포트 (장치관리자에서 확인)": "",
    "MFC_PORT": "COM10",
    "MFC_BAUD": 9600,

    "// DC Power 연결 포트": "",
    "DC_PORT": "COM11",
    "DC_BAUDRATE": 9600,

    "// PLC 연결 포트": "",
    "PLC_PORT": "COM9",

    "// ------- DC 파워 감시 설정 -------": "",
    "// DC 파워 이탈 허용 비율 (0.10 = ±10%)": "",
    "DC_POWER_ERROR_RATIO": 0.10,
    "// DC 파워 이탈 연속 횟수 - 이 횟수 초과 시 공정 중단": "",
    "DC_POWER_ERROR_MAX_COUNT": 5,
    "// DC 저전류 판단 기준값 (A) - 이 값 이하이면 저전류로 감지": "",
    "DC_MIN_CURRENT_ABORT": 0.05,
    "// DC 저전류 연속 횟수 - 이 횟수 초과 시 공정 중단": "",
    "DC_MIN_CURRENT_ABORT_COUNT": 10,
    "// DC 램프업 무응답 판단 시간 (초) - 이 시간 이상 출력 없으면 공정 중단": "",
    "DC_FAIL_MAX_TICKS": 15,

    "// ------- RF 파워 감시 설정 -------": "",
    "// RF For.P 이탈 허용 비율 (0.10 = ±10%) - MAINTAINING 중만 감시": "",
    "RF_POWER_ERROR_RATIO": 0.10,
    "// RF For.P 이탈 연속 횟수 - 이 횟수 초과 시 공정 중단": "",
    "RF_POWER_ERROR_MAX_COUNT": 5,
    "// RF 램프업 무응답 판단 시간 (초)": "",
    "RF_FAIL_MAX_TICKS": 10,
    "// RF Ref.P 임계값 (W) - 이 값 이상이면 대기 시작 (전 구간 감시)": "",
    "RF_REFP_ABORT_THRESHOLD": 20.0,
    "// RF Ref.P 대기 허용 시간 (초) - 이 시간 내 안정 안 되면 공정 중단": "",
    "RF_REFP_WAIT_SEC": 15,

    "// ------- MFC 감시 설정 -------": "",
    "// 가스 유량 이탈 허용 비율 (0.10 = ±10%) - Process Time에서만 감시": "",
    "FLOW_ERROR_TOLERANCE": 0.10,
    "// 가스 유량 이탈 연속 횟수 - 이 횟수 초과 시 구글챗 알림 (공정 유지)": "",
    "FLOW_ERROR_MAX_COUNT": 5,
    "// 압력 이탈 허용 비율 (0.10 = ±10%) - Process Time에서만 감시": "",
    "MFC_PRESSURE_WARN_RATIO": 0.10,
    "// 압력 이탈 연속 횟수 - 이 횟수 초과 시 구글챗 알림 (공정 유지)": "",
    "MFC_PRESSURE_WARN_COUNT": 5
}